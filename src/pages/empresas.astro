---
import ContentPage from '../components/ui/ContentPage.astro';
import TextImageMedia from '../components/ui/TextImageMedia.astro';
import { getPageMeta } from '../data/pages-meta';
import { empresasContent } from '../data/pages-content';
import { images } from '../data/images';
import VenuePackages from '../components/venue/VenuePackages.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import FullWidthVideo from '../components/ui/FullWidthVideo.astro';

const meta = getPageMeta('/empresas');
const { hero, intro, blocks, features, cta } = empresasContent;
const blockImages = [images.empresas.teambuilding, images.empresas.rodajes];
---

<ContentPage
  title={meta.title}
  description={meta.description}
  heroTitle={hero.title}
  heroSubtitle={hero.subtitle}
  heroEyebrow={hero.eyebrow}
  heroImage={images.hero.empresas}
  ctaTitle={cta.title}
  ctaText={cta.text}
  ctaButtonLabel={cta.buttonLabel}
  ctaButtonHref="#solicitud-presupuesto"
>
  <section class="page-content">
    <div class="container page-content__inner page-content__inner--wide page-content__intro">
      <p class="page-content__lead">{intro}</p>
    </div>
  </section>

  {
    blocks.map((block, index) => (
      <section class:list={['page-content', { 'page-content--alt section--alt': index % 2 === 0 }]}>
        <div class:list={['container text-image', { 'text-image--media-left': index === 1 }]}>
          <div class="page-content__inner">
            <h2>{block.title}</h2>
            {block.paragraphs.map((p) => <p>{p}</p>)}
          </div>
          <TextImageMedia src={blockImages[index] ?? images.empresas.teambuilding} alt={block.title} />
        </div>
      </section>
    ))
  }

  <section class="page-content page-content--alt section--alt">
    <div class="container page-content__inner page-content__inner--wide">
      <h2 class="section__title">Por qué Los Collados para su empresa</h2>
      <div class="feature-grid feature-grid--4">
        {features.map((feature) => (
          <article class="feature-grid__card">
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <VenuePackages />

  <FullWidthVideo
    src={images.videos.empresasShowcase}
    alt="La finca Los Collados para empresas y equipos"
  />

  <div id="solicitud-presupuesto">
    <ContactForm
      title="Solicite presupuesto para su empresa"
      intro="Rodajes, teambuilding, retiros o jornada en la finca. Indique fechas, equipo e invitados."
      showPhone={true}
      showDates={true}
      showGuests={true}
      defaultSubject="empresa"
      formId="presupuesto"
    />
  </div>
</ContentPage>
