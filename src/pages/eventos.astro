---
import ContentPage from '../components/ui/ContentPage.astro';
import TextImageMedia from '../components/ui/TextImageMedia.astro';
import { getPageMeta } from '../data/pages-meta';
import { eventosContent } from '../data/pages-content';
import { images } from '../data/images';
import VenuePackages from '../components/venue/VenuePackages.astro';
import AzureaCatering from '../components/venue/AzureaCatering.astro';
import ContactForm from '../components/forms/ContactForm.astro';

const meta = getPageMeta('/eventos');
const { hero, intro, capacity, eventTypes, blocks, venuePackages, cta } = eventosContent;

const eventVenuePackageIds = [
  'finca-espacios',
  'finca-completa',
  'finca-fin-semana',
  'sesiones-fotograficas',
] as const;
---

<ContentPage
  title={meta.title}
  description={meta.description}
  heroTitle={hero.title}
  heroSubtitle={hero.subtitle}
  heroEyebrow={hero.eyebrow}
  heroImage={images.hero.eventos}
  ctaTitle={cta.title}
  ctaText={cta.text}
  ctaButtonLabel={cta.buttonLabel}
  ctaButtonHref="#solicitud-presupuesto"
>
  <section class="page-content">
    <div class="container text-image">
      <div class="page-content__inner page-content__inner--wide">
        <p class="page-content__lead">{intro}</p>
        <h2 class="section__title">{capacity.title}</h2>
        <ul class="capacity-list" style="max-width: 32rem; margin-inline: auto;">
          {capacity.items.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <TextImageMedia src={images.venue.espacios} alt="Celebración al aire libre en la finca" />
    </div>
  </section>

  <section class="page-content page-content--alt section--alt">
    <div class="container page-content__inner page-content__inner--wide">
      <h2 class="section__title">{eventTypes.title}</h2>
      <p class="page-content__lead">{eventTypes.lead}</p>
      <div class="feature-grid feature-grid--3">
        {
          eventTypes.items.map((item) => (
            <article class="feature-grid__card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {
    blocks.map((block) => (
      <section class="page-content">
        <div class="container page-content__inner" style="margin-inline: auto;">
          <h2>{block.title}</h2>
          {block.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </section>
    ))
  }

  <VenuePackages
    packageIds={[...eventVenuePackageIds]}
    title={venuePackages.title}
    lead={venuePackages.lead}
  />

  <AzureaCatering />

  <div id="solicitud-presupuesto">
    <ContactForm
      title="Planifique su evento"
      intro="Bodas, comuniones, cumpleaños, empresas, shootings o sesiones fotográficas. Indique fechas, invitados y tipo de celebración."
      showPhone={true}
      showDates={true}
      showGuests={true}
      defaultSubject="evento"
      formId="presupuesto"
    />
  </div>
</ContentPage>
