---
import ContentPage from '../components/ui/ContentPage.astro';
import TextImageMedia from '../components/ui/TextImageMedia.astro';
import { getPageMeta } from '../data/pages-meta';
import { laCalerillaContent } from '../data/pages-content';
import { images } from '../data/images';
import ContactForm from '../components/forms/ContactForm.astro';

const meta = getPageMeta('/la-calerilla');
const { hero, intro, blocks, features, season, cta } = laCalerillaContent;
const blockImages = [
  images.laCalerilla.campo,
  images.laCalerilla.perdiz,
  images.laCalerilla.gastronomia,
];
---

<ContentPage
  title={meta.title}
  description={meta.description}
  heroTitle={hero.title}
  heroSubtitle={hero.subtitle}
  heroEyebrow={hero.eyebrow}
  heroImage={images.hero.laCalerilla}
  ctaTitle={cta.title}
  ctaText={cta.text}
  ctaButtonLabel={cta.buttonLabel}
  ctaButtonHref="#solicitud-caza"
>
  <section class="page-content">
    <div class="container page-content__inner page-content__inner--wide">
      <p class="page-content__lead">{intro}</p>
      <h2 class="section__title">{season.title}</h2>
      <ul class="capacity-list" style="max-width: 32rem; margin-inline: auto;">
        {season.items.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  {
    blocks.map((block, index) => (
      <section class:list={['page-content', { 'page-content--alt section--alt': index % 2 === 1 }]}>
        <div class:list={['container text-image', { 'text-image--media-left': index === 1 }]}>
          <div class="page-content__inner">
            <h2>{block.title}</h2>
            {block.paragraphs.map((p) => <p>{p}</p>)}
          </div>
          <TextImageMedia src={blockImages[index] ?? images.laCalerilla.campo} alt={block.title} />
        </div>
      </section>
    ))
  }

  <section class="page-content page-content--alt section--alt">
    <div class="container page-content__inner page-content__inner--wide">
      <h2 class="section__title">La Calerilla en resumen</h2>
      <div class="feature-grid feature-grid--4">
        {features.map((feature) => (
          <article class="feature-grid__card">
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <div id="solicitud-caza">
    <ContactForm
      title="Solicite su jornada de caza"
      intro="Indique fechas preferidas, número de tiradores y si desea combinar con alojamiento o restauración. Las fechas de temporada son muy solicitadas."
      showPhone={true}
      showDates={true}
      showGuests={true}
      defaultSubject="caza"
      formId="caza"
    />
  </div>
</ContentPage>
