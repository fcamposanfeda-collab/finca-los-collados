---
import ContentPage from '../components/ui/ContentPage.astro';
import { getPageMeta } from '../data/pages-meta';
import { packsContent } from '../data/pages-content';

const meta = getPageMeta('/packs');
const { hero, intro, packs, cta } = packsContent;
---

<ContentPage
  title={meta.title}
  description={meta.description}
  heroTitle={hero.title}
  heroSubtitle={hero.subtitle}
  heroEyebrow={hero.eyebrow}
  ctaTitle={cta.title}
  ctaText={cta.text}
>
  <section class="page-content">
    <div class="container page-content__inner page-content__inner--wide">
      <p class="page-content__lead">{intro}</p>
      <div class="packs-grid">
        {
          packs.map((pack) => (
            <article class="packs-grid__card">
              <h3>{pack.title}</h3>
              <p>{pack.description}</p>
              <ul class="packs-grid__highlights">
                {pack.highlights.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</ContentPage>
