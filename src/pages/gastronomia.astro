---
import ContentPage from '../components/ui/ContentPage.astro';
import { getPageMeta } from '../data/pages-meta';
import { gastronomiaContent } from '../data/pages-content';

const meta = getPageMeta('/gastronomia');
const { hero, lead, subtitle, description, dishes, quote, features, cta } = gastronomiaContent;
---

<ContentPage
  title={meta.title}
  description={meta.description}
  heroTitle={hero.title}
  heroSubtitle={hero.subtitle}
  heroEyebrow={hero.eyebrow}
  ctaTitle={cta.title}
  ctaText={cta.text}
>
  <section class="page-content">
    <div class="container page-content__inner" style="margin-inline: auto; text-align: center;">
      <p class="page-content__lead">{lead}</p>
      <p style="font-style: italic; color: var(--color-accent); margin-bottom: 1.5rem;">{subtitle}</p>
      <p>{description}</p>
      <p style="font-weight: 500; color: var(--color-text);">{dishes}</p>
      <blockquote class="gastronomia-quote">{quote}</blockquote>
    </div>
  </section>

  <section class="page-content page-content--alt section--alt">
    <div class="container page-content__inner page-content__inner--wide">
      <div class="feature-grid">
        {features.map((feature) => (
          <article class="feature-grid__card">
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</ContentPage>
