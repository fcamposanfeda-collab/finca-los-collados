---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPageMeta } from '../data/pages-meta';
import Hero from '../components/sections/Hero.astro';
import HomePillars from '../components/sections/HomePillars.astro';
import HomeTeasers from '../components/sections/HomeTeasers.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';

const meta = getPageMeta('/');
---

<BaseLayout title={meta.title} description={meta.description}>
  <Hero />
  <HomePillars />
  <HomeTeasers />
  <CtaBanner
    title="¿Listo para su escapada rural?"
    text="Reserve online o escríbanos para diseñar su estancia, evento íntimo o jornada de empresa en un entorno sin prisas."
  />
</BaseLayout>
