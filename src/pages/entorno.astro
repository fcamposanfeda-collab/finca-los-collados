---
import ContentPage from '../components/ui/ContentPage.astro';
import ContentImage from '../components/ui/ContentImage.astro';
import { getPageMeta } from '../data/pages-meta';
import { entornoContent } from '../data/pages-content';
import { images } from '../data/images';

const meta = getPageMeta('/entorno');
const { hero, intro, places, cta } = entornoContent;

function getPlaceImage(title: string) {
  return images.entorno[title as keyof typeof images.entorno] ?? images.hero.entorno;
}
---

<ContentPage
  title={meta.title}
  description={meta.description}
  heroTitle={hero.title}
  heroSubtitle={hero.subtitle}
  heroEyebrow={hero.eyebrow}
  heroImage={images.hero.entorno}
  ctaTitle={cta.title}
  ctaText={cta.text}
>
  <section class="page-content">
    <div class="container page-content__inner page-content__inner--wide">
      <p class="page-content__lead">{intro}</p>
      <div class="feature-grid">
        {
          places.map((place) => (
            <article class="feature-grid__card feature-grid__card--media">
              <div class="card-media">
                <ContentImage src={getPlaceImage(place.title)} alt={place.title} />
              </div>
              <div class="card-body">
                <h3>{place.title}</h3>
                <p>{place.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</ContentPage>
