---
import ContentPage from '../components/ui/ContentPage.astro';
import TextImageMedia from '../components/ui/TextImageMedia.astro';
import ImageCarousel from '../components/ui/ImageCarousel.astro';
import FullWidthVideo from '../components/ui/FullWidthVideo.astro';
import { getPageMeta } from '../data/pages-meta';
import { laFincaContent } from '../data/pages-content';
import { images } from '../data/images';
import { withBase } from '../utils/paths';

const meta = getPageMeta('/la-finca');
const { hero, blocks, features, cta } = laFincaContent;
---

<ContentPage
  title={meta.title}
  description={meta.description}
  heroTitle={hero.title}
  heroSubtitle={hero.subtitle}
  heroEyebrow={hero.eyebrow}
  heroImage={images.hero.laFinca}
  ctaTitle={cta.title}
  ctaText={cta.text}
>
  {
    blocks.map((block, index) => (
      <section class:list={['page-content', { 'page-content--alt section--alt': index % 2 === 1 }]}>
        <div class:list={['container text-image', { 'text-image--media-left': index === 1 }]}>
          <div class="page-content__inner">
            <h2>{block.title}</h2>
            {block.paragraphs.map((p) => <p>{p}</p>)}
          </div>
          {
            index === 1 ? (
              <div class="text-image__media">
                <ImageCarousel slides={images.laFinca.gallery} id="la-finca-espacios" />
              </div>
            ) : (
              <TextImageMedia
                video={images.videos.laFincaCulturas}
                alt={block.title}
                poster={images.laFinca.culturas}
                startTime={5}
              />
            )
          }
        </div>
      </section>
    ))
  }

  <section class="page-content page-content--alt section--alt">
    <div class="container text-image">
      <div class="page-content__inner">
        <h2>La Calerilla</h2>
        <p>
          Dentro de Los Collados de San Miguel, La Calerilla es nuestra zona cinegética dedicada a la
          tradición de la perdiz roja en mano, en un entorno natural de Campos de Montiel.
        </p>
        <p>
          De octubre a febrero organizamos jornadas de caza que pueden combinarse con alojamiento en
          bungalows y con nuestra gastronomía manchega.
        </p>
        <a href={withBase('/la-calerilla')} class="btn">Descubrir La Calerilla</a>
      </div>
      <TextImageMedia src={images.laCalerilla.campo} alt="Campo de caza en La Calerilla" />
    </div>
  </section>

  <FullWidthVideo
    src={images.videos.fincaShowcase}
    alt="Paisaje y entorno de La Finca Los Collados de San Miguel"
    objectPosition="center 42%"
  />

  <section class="page-content">
    <div class="container page-content__inner page-content__inner--wide">
      <h2 class="section__title">Destacados</h2>
      <div class="feature-grid feature-grid--4">
        {features.map((feature) => (
          <article class="feature-grid__card">
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</ContentPage>
