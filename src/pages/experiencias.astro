---
import ContentPage from '../components/ui/ContentPage.astro';
import ContentImage from '../components/ui/ContentImage.astro';
import { getPageMeta } from '../data/pages-meta';
import { experienciasContent } from '../data/pages-content';
import { images } from '../data/images';

const meta = getPageMeta('/experiencias');
const { hero, intro, detail, note, cards, activities, cta } = experienciasContent;
const cardImages = [
  images.experiencias.montiel,
  images.experiencias.mancha,
  images.experiencias.gastronomia,
  images.experiencias.deporte,
];
---

<ContentPage
  title={meta.title}
  description={meta.description}
  heroTitle={hero.title}
  heroSubtitle={hero.subtitle}
  heroEyebrow={hero.eyebrow}
  heroImage={images.hero.experiencias}
  ctaTitle={cta.title}
  ctaText={cta.text}
>
  <section class="page-content">
    <div class="container">
      <p class="page-content__lead page-content__lead--full">{intro}</p>
      <p class="page-content__lead page-content__lead--full">{detail}</p>
      <div class="feature-grid">
        {
          cards.map((card, index) => (
            <article class="feature-grid__card feature-grid__card--media">
              <div class="card-media">
                <ContentImage src={cardImages[index] ?? images.experiencias.montiel} alt={card.title} />
              </div>
              <div class="card-body">
                <h3>{card.title}</h3>
                <p>{card.description}</p>
              </div>
            </article>
          ))
        }
      </div>
      <ul class="activities-tags" aria-label="Actividades disponibles">
        {activities.map((activity) => <li>{activity}</li>)}
      </ul>
      <p class="page-content__lead page-content__lead--full experiencias-note">{note}</p>
    </div>
  </section>
</ContentPage>

<style>
  .experiencias-note {
    font-style: italic;
  }
</style>
