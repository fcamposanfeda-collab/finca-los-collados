---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from './PageHero.astro';
import CtaBanner from './CtaBanner.astro';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle?: string;
  heroEyebrow?: string;
  ctaTitle?: string;
  ctaText?: string;
  ctaButtonLabel?: string;
  ctaButtonHref?: string;
}

const {
  title,
  description,
  heroTitle,
  heroSubtitle,
  heroEyebrow,
  ctaTitle,
  ctaText,
  ctaButtonLabel,
  ctaButtonHref,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <PageHero title={heroTitle} subtitle={heroSubtitle} eyebrow={heroEyebrow} />
  <slot />
  {
    ctaTitle && ctaText && (
      <CtaBanner
        title={ctaTitle}
        text={ctaText}
        buttonLabel={ctaButtonLabel}
        buttonHref={ctaButtonHref}
      />
    )
  }
</BaseLayout>
