---
import { site } from '../../data/site';
import { withBase } from '../../utils/paths';

interface Props {
  title: string;
  text: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const {
  title,
  text,
  buttonLabel = 'Reservar',
  buttonHref = site.bookingUrl,
} = Astro.props;
---

<section class="cta-banner section" aria-labelledby="cta-banner-title">
  <div class="container cta-banner__inner">
    <div class="cta-banner__text">
      <h2 id="cta-banner-title" class="cta-banner__title">{title}</h2>
      <p class="cta-banner__desc">{text}</p>
    </div>
    <div class="cta-banner__actions">
      <a href={withBase(buttonHref)} class="btn">{buttonLabel}</a>
      <a href={withBase('/contacto')} class="btn btn--outline cta-banner__outline">Contactar</a>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    background: var(--color-bg-alt);
  }

  .cta-banner__inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-bg);
  }

  .cta-banner__title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    color: var(--color-secondary);
  }

  .cta-banner__desc {
    margin: 0;
    max-width: 40rem;
    color: var(--color-muted);
  }

  .cta-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    width: 100%;
  }

  .cta-banner__actions .btn {
    flex: 1 1 10.5rem;
    min-width: 10.5rem;
    min-height: 3rem;
    padding-inline: 1.25rem;
    text-align: center;
  }

  .cta-banner__outline {
    border-color: var(--color-primary);
  }

  @media (min-width: 768px) {
    .cta-banner__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .cta-banner__actions {
      width: auto;
      flex-shrink: 0;
    }

    .cta-banner__actions .btn {
      flex: 0 0 10.5rem;
      width: 10.5rem;
    }
  }
</style>
