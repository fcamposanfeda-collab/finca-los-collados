---
interface Props {
  src: string;
  alt: string;
  objectPosition?: string;
  playbackRate?: number;
}

const { src, alt, objectPosition = 'center center', playbackRate = 1 } = Astro.props;
---

<section class="full-width-video" aria-label={alt} data-playback-rate={playbackRate}>
  <video
    src={encodeURI(src)}
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    style={`object-position: ${objectPosition}`}
  ></video>
</section>

<style>
  .full-width-video {
    width: 100%;
    overflow: hidden;
    background: var(--color-secondary);
  }

  .full-width-video video {
    display: block;
    width: 100%;
    height: clamp(10rem, 24vw, 18rem);
    object-fit: cover;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-playback-rate]').forEach((section) => {
    const rate = Number(section.dataset.playbackRate);
    if (!Number.isFinite(rate) || rate === 1) return;

    const video = section.querySelector('video');
    if (!video) return;

    const applyRate = () => {
      video.playbackRate = rate;
    };

    applyRate();
    video.addEventListener('loadedmetadata', applyRate);
  });
</script>
