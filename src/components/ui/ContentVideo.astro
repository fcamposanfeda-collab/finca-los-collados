---
interface Props {
  src: string;
  alt: string;
  class?: string;
  aspect?: 'landscape' | 'square' | 'wide';
  poster?: string;
  startTime?: number;
}

const { src, alt, class: className, aspect = 'landscape', poster, startTime = 0 } = Astro.props;
---

<div class:list={['content-video', `content-video--${aspect}`, className]}>
  <video
    src={src}
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={poster}
    aria-label={alt}
    data-start-time={startTime > 0 ? startTime : undefined}
  ></video>
</div>

<style>
  .content-video {
    overflow: hidden;
    border-radius: 0.5rem;
    background: var(--color-bg-alt);
  }

  .content-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .content-video--landscape {
    min-height: 16rem;
    aspect-ratio: 4 / 3;
  }

  .content-video--wide {
    min-height: 14rem;
    aspect-ratio: 16 / 9;
  }

  .content-video--square {
    aspect-ratio: 1;
  }
</style>

<script>
  document.querySelectorAll<HTMLVideoElement>('video[data-start-time]').forEach((video) => {
    const start = Number(video.dataset.startTime);
    if (!Number.isFinite(start) || start <= 0) return;

    const seekToStart = () => {
      if (video.duration && start < video.duration) {
        video.currentTime = start;
      }
    };

    video.addEventListener('loadedmetadata', seekToStart);
    video.addEventListener('timeupdate', () => {
      if (video.duration && video.currentTime >= video.duration - 0.05) {
        seekToStart();
      }
    });
  });
</script>
