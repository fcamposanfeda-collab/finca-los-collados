---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPageMeta } from '../data/pages-meta';

interface Props {
  legalTitle: string;
}

const { legalTitle } = Astro.props;
const path = (Astro.url.pathname.replace(/\/$/, '') || '/') as Parameters<typeof getPageMeta>[0];
const meta = getPageMeta(path);
---

<BaseLayout title={meta.title} description={meta.description}>
  <section class="section">
    <div class="container legal">
      <h1>{legalTitle}</h1>
      <p class="legal__notice">
        Contenido legal pendiente de migrar desde la web actual en WordPress. Se trasladará el texto
        completo de <a href={`https://loscolladosdesanmiguel.com${path}`}>loscolladosdesanmiguel.com{path}</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .legal {
    max-width: 48rem;
  }

  .legal h1 {
    margin: 0 0 1.5rem;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    color: var(--color-secondary);
  }

  .legal__notice {
    color: var(--color-muted);
    line-height: 1.7;
  }

  .legal__notice a {
    color: var(--color-primary);
    font-weight: 500;
  }
</style>
