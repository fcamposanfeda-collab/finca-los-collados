---
import { site } from '../../data/site';
import { legalNav, footerNav } from '../../data/navigation';
import { contact } from '../../data/contact';
---

<footer class="footer" aria-label="Pie de página">
  <div class="footer__main container">
    <div class="footer__col">
      <h2 class="footer__title">{site.name}</h2>
      <p class="footer__tagline">{site.tagline}</p>
      <address class="footer__address">
        {contact.address}<br />
        {contact.city}
      </address>
      <div class="footer__contact">
        <h2 class="footer__title">Contacto</h2>
        <p>
          <a href={`tel:${contact.phone}`}>{contact.phoneDisplay}</a>
        </p>
        <p>
          <a href={`tel:${contact.phoneAlt}`}>{contact.phoneAltDisplay}</a>
        </p>
        <p>
          <a href={`mailto:${contact.email}`}>{contact.email}</a>
        </p>
      </div>
      <div class="footer__social-block">
        <h2 class="footer__title">Síguenos</h2>
        <div class="footer__social">
          <a href={contact.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            Facebook
          </a>
          <a href={contact.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            Instagram
          </a>
        </div>
      </div>
    </div>

    <div class="footer__col">
      <h2 class="footer__title">Explorar</h2>
      <nav aria-label="Mapa del sitio">
        <ul class="footer__sitemap">
          {footerNav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

  </div>

  <div class="footer__bottom container">
    <p class="footer__copyright">{site.copyright}</p>
    <nav class="footer__legal" aria-label="Enlaces legales">
      <ul class="footer__legal-list">
        {
          legalNav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-footer-bg);
    color: var(--color-on-primary);
  }

  .footer__main {
    display: grid;
    gap: 2rem;
    padding-block: var(--section-padding-mobile);
  }

  .footer__title {
    margin: 0 0 1rem;
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .footer__tagline {
    margin: 0 0 1rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .footer__address {
    font-style: normal;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
  }

  .footer__contact {
    margin-top: 1.5rem;
  }

  .footer__contact p {
    margin: 0 0 0.5rem;
  }

  .footer__social-block {
    margin-top: 1.5rem;
  }

  .footer a {
    color: rgba(255, 255, 255, 0.9);
    transition: color var(--transition-fast);
  }

  .footer a:hover {
    color: var(--color-accent);
  }

  .footer__social {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__sitemap {
    display: grid;
    gap: 0.375rem;
  }

  .footer__sitemap a {
    font-size: 0.9375rem;
  }

  @media (min-width: 1024px) {
    .footer__main {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-block: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .footer__copyright {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer__legal-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }

  .footer__legal-list a {
    font-size: 0.875rem;
  }

  @media (min-width: 768px) {
    .footer__main {
      grid-template-columns: repeat(2, 1fr);
      padding-block: var(--section-padding-desktop);
    }

    .footer__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
