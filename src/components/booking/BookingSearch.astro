---
import { booking, isWidgetConfigured } from '../../data/booking';

const today = new Date().toISOString().slice(0, 10);
---

<section class="booking-search section" aria-labelledby="booking-search-title">
  <div class="container booking-search__inner">
    <div class="booking-search__intro">
      <h2 id="booking-search-title">Buscar disponibilidad</h2>
      <p>
        Seleccione fechas y adultos (máx. 16 en 8 bungalows). El buscador abre vuestra ficha en
        Booking.com con las fechas ya rellenadas, o WhatsApp para consultas personalizadas.
      </p>
    </div>

    <form class="booking-search__form" data-booking-search novalidate>
      <div class="booking-search__fields">
        <div class="booking-search__field">
          <label for="check-in">Entrada</label>
          <input id="check-in" name="checkIn" type="date" min={today} required />
        </div>
        <div class="booking-search__field">
          <label for="check-out">Salida</label>
          <input id="check-out" name="checkOut" type="date" min={today} required />
        </div>
        <div class="booking-search__field">
          <label for="adults">Adultos</label>
          <select id="adults" name="adults" required>
            {
              Array.from({ length: 16 }, (_, i) => i + 1).map((n) => (
                <option value={n} selected={n === 2}>
                  {n}
                </option>
              ))
            }
          </select>
        </div>
      </div>

      <div class="booking-search__actions">
        {
          isWidgetConfigured() ? (
            <button type="submit" class="btn" data-action="widget">
              Buscar en motor directo
            </button>
          ) : (
            <button type="submit" class="btn" data-action="booking-com">
              Buscar en Booking.com
            </button>
          )
        }
        <button type="submit" class="btn btn--outline" data-action="whatsapp">
          Consultar por WhatsApp
        </button>
      </div>

      <p class="booking-search__note" data-booking-message hidden></p>
    </form>
  </div>
</section>

<script define:vars={{ bookingComBase: booking.bookingCom.propertyUrl, whatsappPhone: booking.whatsapp.phone, widgetConfigured: isWidgetConfigured(), roomCount: booking.accommodation.roomCount, maxAdultsPerRoom: booking.accommodation.maxAdultsPerRoom }}>
  const form = document.querySelector('[data-booking-search]');
  const messageEl = document.querySelector('[data-booking-message]');
  const checkInInput = document.querySelector('#check-in');
  const checkOutInput = document.querySelector('#check-out');

  checkInInput?.addEventListener('change', () => {
    if (checkOutInput && checkInInput.value) {
      checkOutInput.min = checkInInput.value;
      if (checkOutInput.value && checkOutInput.value <= checkInInput.value) {
        checkOutInput.value = '';
      }
    }
  });

  function buildBookingComUrl(params) {
    const url = new URL(bookingComBase);
    if (params.checkIn) url.searchParams.set('checkin', params.checkIn);
    if (params.checkOut) url.searchParams.set('checkout', params.checkOut);
    if (params.adults > 0) {
      url.searchParams.set('group_adults', String(params.adults));
      const rooms = Math.min(roomCount, Math.ceil(params.adults / maxAdultsPerRoom));
      url.searchParams.set('no_rooms', String(rooms));
    }
    return url.toString();
  }

  function buildWhatsAppUrl(params) {
    const lines = [
      'Hola, me gustaría consultar disponibilidad en Finca Los Collados de San Miguel.',
      params.checkIn && params.checkOut ? `Entrada: ${params.checkIn}` : '',
      params.checkIn && params.checkOut ? `Salida: ${params.checkOut}` : '',
      params.adults ? `Adultos: ${params.adults}` : '',
    ].filter(Boolean);
    return `https://wa.me/${whatsappPhone}?text=${encodeURIComponent(lines.join('\n'))}`;
  }

  form?.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLButtonElement) || target.type !== 'submit') return;

    event.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);
    const params = {
      checkIn: String(data.get('checkIn') ?? ''),
      checkOut: String(data.get('checkOut') ?? ''),
      adults: Number(data.get('adults') ?? 2),
    };

    if (params.checkOut <= params.checkIn) {
      if (messageEl) {
        messageEl.hidden = false;
        messageEl.textContent = 'La fecha de salida debe ser posterior a la de entrada.';
      }
      return;
    }

    if (messageEl) messageEl.hidden = true;

    const action = target.dataset.action;

    if (action === 'whatsapp') {
      window.open(buildWhatsAppUrl(params), '_blank', 'noopener,noreferrer');
      return;
    }

    if (action === 'booking-com') {
      window.open(buildBookingComUrl(params), '_blank', 'noopener,noreferrer');
      return;
    }

    if (action === 'widget' && widgetConfigured) {
      window.dispatchEvent(new CustomEvent('booking:search', { detail: params }));
      if (messageEl) {
        messageEl.hidden = false;
        messageEl.textContent = 'Búsqueda enviada al motor de reservas. Revise el calendario inferior.';
      }
      document.querySelector('[data-booking-widget]')?.scrollIntoView({ behavior: 'smooth' });
    }
  });
</script>

<style>
  .booking-search__inner {
    padding: 2rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .booking-search__intro h2 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    color: var(--color-secondary);
  }

  .booking-search__intro p {
    margin: 0 0 1.5rem;
    color: var(--color-muted);
  }

  .booking-search__fields {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .booking-search__field label {
    display: block;
    margin-bottom: 0.375rem;
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .booking-search__field input,
  .booking-search__field select {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-bg-alt);
    color: var(--color-text);
  }

  .booking-search__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .booking-search__note {
    margin: 1rem 0 0;
    font-size: 0.9375rem;
    color: var(--color-primary);
  }

  @media (min-width: 768px) {
    .booking-search__fields {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
