---
import { homeContent } from '../../data/home-content';
import { site } from '../../data/site';
import { images } from '../../data/images';
import ContentImage from '../ui/ContentImage.astro';

const { finca } = homeContent;
---

<section id={finca.id} class="section">
  <div class="container">
    <h2 class="section__title">{finca.title}</h2>
    <div class="finca__grid">
      <div class="finca__text">
        {finca.paragraphs.map((p) => <p>{p}</p>)}
        <a href={site.bookingUrl} class="btn">Reservar</a>
      </div>
      <div class="finca__media">
        <ContentImage src={images.hero.laFinca} alt="Paisaje de la finca Los Collados" />
      </div>
    </div>
  </div>
</section>

<style>
  .finca__grid {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }

  .finca__text p {
    margin: 0 0 1rem;
    color: var(--color-muted);
  }

  .finca__text .btn {
    margin-top: 0.5rem;
  }

  .finca__media :global(.content-image) {
    border-radius: 0.5rem;
    min-height: 18rem;
  }

  @media (min-width: 768px) {
    .finca__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
