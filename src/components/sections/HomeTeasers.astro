---
import { homeTeasers } from '../../data/pages-content';
import { images } from '../../data/images';
import ContentImage from '../ui/ContentImage.astro';
---

<section class="section section--alt home-teasers" aria-label="Descubra la finca">
  <div class="container">
    <h2 class="section__title">Descubre la Finca Los Collados de San Miguel</h2>
    <p class="section__lead">
      Cada área de la finca tiene su propia página con toda la información: alojamiento en bungalows,
      gastronomía con Azurea, celebraciones al aire libre, propuestas para empresas y mucho más.
      Elija por dónde empezar a planificar su visita.
    </p>
    <div class="home-teasers__grid">
      {
        homeTeasers.map((item) => (
          <a href={item.href} class="home-teasers__card">
            <div class="card-media">
              <ContentImage
                src={images.teasers[item.href as keyof typeof images.teasers]}
                alt={item.title}
              />
            </div>
            <div class="card-body">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
              <span class="home-teasers__link">Ver más</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .home-teasers__grid {
    display: grid;
    gap: 1.25rem;
  }

  .home-teasers__card {
    display: block;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .home-teasers__card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(44, 36, 25, 0.08);
  }

  .home-teasers__card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
    color: var(--color-secondary);
  }

  .home-teasers__card p {
    margin: 0 0 1rem;
    font-size: 0.9375rem;
    color: var(--color-muted);
  }

  .home-teasers__link {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  @media (min-width: 768px) {
    .home-teasers__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .home-teasers__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
