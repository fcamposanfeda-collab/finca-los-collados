---
import { homeTeasers } from '../../data/pages-content';
---

<section class="section section--alt home-teasers" aria-label="Descubra la finca">
  <div class="container">
    <h2 class="section__title">Descubra Los Collados</h2>
    <p class="section__lead">
      Cada área de la finca tiene su propia página con toda la información: alojamiento, gastronomía,
      empresas, eventos y más.
    </p>
    <div class="home-teasers__grid">
      {
        homeTeasers.map((item) => (
          <a href={item.href} class="home-teasers__card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <span class="home-teasers__link">Ver más</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .home-teasers__grid {
    display: grid;
    gap: 1.25rem;
  }

  .home-teasers__card {
    display: block;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .home-teasers__card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(44, 36, 25, 0.08);
  }

  .home-teasers__card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
    color: var(--color-secondary);
  }

  .home-teasers__card p {
    margin: 0 0 1rem;
    font-size: 0.9375rem;
    color: var(--color-muted);
  }

  .home-teasers__link {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  @media (min-width: 768px) {
    .home-teasers__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .home-teasers__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
