---
import { gastronomiaContent } from '../../data/pages-content';
import { images } from '../../data/images';
import ContentImage from '../ui/ContentImage.astro';
import ImageCarousel from '../ui/ImageCarousel.astro';
import { withBase } from '../../utils/paths';

const { moments } = gastronomiaContent;
---

<section class="section gastronomia-moments" aria-labelledby="gastronomia-moments-title">
  <div class="container">
    <header class="gastronomia-moments__header">
      <h2 id="gastronomia-moments-title" class="section__title">{moments.title}</h2>
      <p class="section__lead gastronomia-moments__lead">{moments.lead}</p>
    </header>

    <div class="gastronomia-moments__intro">
      <div class="gastronomia-moments__visual">
        <ContentImage
          src={images.gastronomiaMoments.mesaDetalle}
          alt="Mesa servida con detalle en Los Collados de San Miguel"
          aspect="portrait"
        />
      </div>

      <div class="gastronomia-moments__copy">
        {moments.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        <p class="gastronomia-moments__links">
          <a href={withBase('/eventos')}>Eventos</a>
          <span aria-hidden="true">·</span>
          <a href={withBase('/packs')}>Packs</a>
          <span aria-hidden="true">·</span>
          <a href={withBase('/la-finca')}>La finca</a>
        </p>
      </div>
    </div>

    <div class="gastronomia-moments__platos" aria-label="Galería de platos">
      <div class="gastronomia-moments__platos-header">
        <p class="gastronomia-moments__eyebrow">De la cocina</p>
        <h3 class="gastronomia-moments__platos-title">Una muestra de la mesa</h3>
      </div>

      <ImageCarousel
        slides={images.gastronomiaMoments.platos}
        id="gastronomia-platos"
        aspect="wide"
        variant="gallery"
        showCaption={true}
        autoplayInterval={5000}
      />
    </div>
  </div>
</section>

<style>
  .gastronomia-moments__header {
    max-width: 42rem;
    margin-inline: auto;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .gastronomia-moments__lead {
    margin-bottom: 0;
  }

  .gastronomia-moments__intro {
    display: grid;
    gap: 2rem;
    align-items: stretch;
  }

  .gastronomia-moments__visual {
    display: flex;
    justify-content: center;
  }

  .gastronomia-moments__visual :global(.content-image--portrait) {
    width: min(100%, 22rem);
    height: 100%;
  }

  .gastronomia-moments__copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .gastronomia-moments__copy p {
    margin: 0 0 1rem;
    color: var(--color-muted);
    line-height: 1.75;
  }

  .gastronomia-moments__copy p:last-of-type {
    margin-bottom: 1.25rem;
  }

  .gastronomia-moments__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .gastronomia-moments__links a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .gastronomia-moments__links a:hover {
    text-decoration: underline;
  }

  .gastronomia-moments__links span {
    color: var(--color-border);
  }

  .gastronomia-moments__platos {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-border);
  }

  .gastronomia-moments__platos-header {
    max-width: 36rem;
    margin: 0 auto 1.5rem;
    text-align: center;
  }

  .gastronomia-moments__eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .gastronomia-moments__platos-title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    color: var(--color-secondary);
  }

  @media (min-width: 768px) {
    .gastronomia-moments__intro {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }

    .gastronomia-moments__visual {
      justify-content: stretch;
      align-self: stretch;
    }

    .gastronomia-moments__visual :global(.content-image--portrait) {
      width: 100%;
      max-width: none;
      height: 100%;
      aspect-ratio: auto;
      min-height: 24rem;
    }

    .gastronomia-moments__platos {
      margin-top: 3.5rem;
      padding-top: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .gastronomia-moments__header {
      margin-bottom: 3rem;
    }

    .gastronomia-moments__intro {
      gap: 3rem;
    }
  }
</style>
