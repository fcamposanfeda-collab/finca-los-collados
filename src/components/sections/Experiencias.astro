---
import { homeContent } from '../../data/home-content';
import { site } from '../../data/site';

const { experiencias } = homeContent;
---

<section id={experiencias.id} class="section section--alt">
  <div class="container">
    <h2 class="section__title">{experiencias.title}</h2>
    <p class="section__lead">{experiencias.intro}</p>
    <p class="experiencias__detail">{experiencias.detail}</p>

    <div class="experiencias__cards">
      {
        experiencias.cards.map((card) => (
          <article class="experiencias__card">
            <h3>{card.title}</h3>
            <p>{card.description}</p>
          </article>
        ))
      }
    </div>

    <ul class="experiencias__activities" aria-label="Actividades disponibles">
      {experiencias.activities.map((activity) => <li>{activity}</li>)}
    </ul>

    <p class="experiencias__note">{experiencias.note}</p>
    <div class="experiencias__cta">
      <a href={site.bookingUrl} class="btn">Reservar</a>
    </div>
  </div>
</section>

<style>
  .experiencias__detail {
    max-width: 42rem;
    margin: 0 auto 2.5rem;
    text-align: center;
    color: var(--color-muted);
  }

  .experiencias__cards {
    display: grid;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .experiencias__card {
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .experiencias__card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
    color: var(--color-secondary);
  }

  .experiencias__card p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9375rem;
  }

  .experiencias__activities {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1rem;
    margin-bottom: 1.5rem;
  }

  .experiencias__activities li {
    padding: 0.375rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    background: rgba(74, 103, 65, 0.1);
    border-radius: 999px;
  }

  .experiencias__note {
    max-width: 42rem;
    margin: 0 auto 1.5rem;
    text-align: center;
    font-size: 0.9375rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .experiencias__cta {
    text-align: center;
  }

  @media (min-width: 768px) {
    .experiencias__cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .experiencias__cards {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
